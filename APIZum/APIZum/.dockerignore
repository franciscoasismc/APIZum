# ── .dockerignore — Backend Spring Boot ──────────────────────────
# Excluye archivos innecesarios del contexto de build de Docker.

# Carpeta de build generada localmente
build/
.gradle/

# Archivos de configuración del IDE
.idea/
*.iml
*.iws
*.ipr

# Sistema operativo
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentación y archivos de ayuda
HELP.md
README.md
